# Database Configuration
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=lili_hotel
DB_USER=root
DB_PASS=change-me

# Security
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# LINE Messaging API
LINE_CHANNEL_ACCESS_TOKEN=your-line-channel-access-token
LINE_CHANNEL_SECRET=your-line-channel-secret

# LINE Service HTTP Client Configuration
# 功能开关:控制是否使用 HTTP 客户端调用 line_app (新版本)
USE_LINE_HTTP_CLIENT=false
LINE_APP_URL=http://localhost:3001

# OpenAI Configuration
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4
OPENAI_BASE_URL=https://api.openai.com/v1

# Facebook
VITE_FACEBOOK_APP_ID=851348804294287
FACEBOOK_GRAPH_API_VERSION=v24.0
# Facebook API (外部 Meta Page 服務)
FB_API_URL=https://api-youth-tycg.star-bit.io

# 公開訪問的基礎 URL（依部署環境設定）
PUBLIC_BASE=https://linebot.star-bit.io

# Default room image (fallback when KB has no image)
DEFAULT_ROOM_IMAGE_URL=https://linebot.star-bit.io/uploads/default_room.jpg

# File Storage Configuration
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760
ALLOWED_IMAGE_TYPES=jpg,jpeg,png,webp

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# Environment
ENVIRONMENT=development
DEBUG=True
